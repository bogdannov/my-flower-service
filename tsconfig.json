{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleDetection": "force",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "es2020",
      "dom"
    ]
  },
  "include": ["src/**/*"]
}
