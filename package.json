{
  "name": "@bogdannov/my-flowers-types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for my-flowers-service",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bogdannov/my-flower-service.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "tsc": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "lint:fix:unsafe": "biome check --fix --unsafe",
    "local:up": "docker compose up -d",
    "local:down": "docker compose down",
    "local:deploy": "node --env-file=.env.local ./node_modules/.bin/serverless deploy --stage local",
    "local:remove": "serverless remove --stage local",
    "dev:deploy": "serverless deploy --stage dev",
    "dev:remove": "serverless remove --stage dev",
    "prod:deploy": "serverless deploy --stage prod",
    "prod:remove": "serverless remove --stage prod",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.777.0",
    "@aws-sdk/client-sqs": "^3.777.0",
    "@aws-sdk/lib-dynamodb": "^3.1038.0",
    "jose": "^6.2.3",
    "neverthrow": "^8.2.0",
    "serialize-error": "^12.0.0",
    "serverless": "^4.9.1",
    "typed-inject": "^5.0.0",
    "ulid": "^3.0.2",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/aws-lambda": "^8.10.148",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/sinon": "^17.0.4",
    "mocha": "^11.7.1",
    "serverless-lift": "^1.31.0",
    "serverless-localstack": "^1.3.1",
    "serverless-offline": "^14.4.0",
    "sinon": "^21.0.0",
    "testcontainers": "^11.14.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.5"
  }
}
